{
  "snapshotFormat": {
    "printBasicPrototype": true
  },
  "transform": {
    "^.+\\.vue$": "<rootDir>/test/vue-transformer.cjs",
    "^.+\\.ts$": ["ts-jest", { "tsconfig": { "allowJs": true } }],
    "^.+\\.js$": "babel-jest"
  },
  "testEnvironment": "jsdom",
  "testPathIgnorePatterns": ["/node_modules/", "/test-e2e/"],
  "moduleFileExtensions": ["ts", "js", "json", "vue"]
}
